<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS site physical path should point here. This site has no content of its
  own — it exists purely so IIS + Application Request Routing (ARR) + URL
  Rewrite can reverse-proxy every request to the SmartTradeAI app process
  running locally on 127.0.0.1:5000 (see ../serve.py and ../README.md).

  Requires, on the IIS machine:
    - Application Request Routing (ARR) installed, with the proxy feature
      enabled server-wide (deploy/setup_iis.ps1 does this)
    - URL Rewrite module installed
    - The "WebSocket Protocol" Windows feature enabled (for the live price
      stream / Socket.IO — deploy/setup_iis.ps1 does this too)
-->
<configuration>
  <system.webServer>
    <webSocket enabled="true" />
    <rewrite>
      <rules>
        <rule name="SmartTradeAI reverse proxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:5000/{R:1}" />
        </rule>
      </rules>
    </rewrite>
    <!-- Let Flask's own error pages (404/500/etc.) through instead of IIS's -->
    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
