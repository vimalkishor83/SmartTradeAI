# ─── Application ───
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-this
JWT_SECRET_KEY=your-jwt-secret-key-change-this
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ─── Database ───
# Development (SQLite - auto-created)
DATABASE_URL=sqlite:///smarttrade_dev.db
# Production (PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/smarttrade_db

# ─── Redis (optional, for caching & rate limiting) ───
REDIS_URL=redis://localhost:6379/0

# ─── Email (for notifications) ───
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@smarttradeai.com

# ─── Telegram Bot (for alerts) ───
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─── Market Data APIs ───
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET=your-binance-secret
ALPHAVANTAGE_API_KEY=your-alphavantage-key
ZERODHA_API_KEY=your-zerodha-key
ZERODHA_SECRET=your-zerodha-secret
NEWS_API_KEY=your-newsapi-key

# ─── JWT Token Expiry ───
JWT_ACCESS_EXPIRES_HOURS=24
JWT_REFRESH_EXPIRES_DAYS=30

# ─── Web Push (VAPID) — generate with: python scripts/gen_vapid_keys.py ───
VAPID_PUBLIC_KEY=your-vapid-public-key-base64url
VAPID_PRIVATE_KEY=your-vapid-private-key-pem
VAPID_CLAIMS_EMAIL=mailto:admin@smarttradeai.com
